{
  "name": "b2c-plugin-help-docs-viewer",
  "version": "0.4.1",
  "description": "B2C CLI plugin for Salesforce Help search and article details.",
  "homepage": "https://github.com/taurgis/b2c-plugin-docs-viewer#readme",
  "bugs": {
    "url": "https://github.com/taurgis/b2c-plugin-docs-viewer/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/taurgis/b2c-plugin-docs-viewer.git"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "regression:suite": "node testing/regression/run-suite.mjs",
    "regression:promote": "node testing/regression/run-suite.mjs --promote",
    "regression:check": "node testing/regression/run-suite.mjs --strict",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix"
  },
  "keywords": [
    "b2c",
    "sfcc",
    "help",
    "docs",
    "oclif",
    "plugin"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@oclif/core": "^4.8.1",
    "jsdom": "^24.0.0",
    "keytar": "^7.9.0",
    "playwright": "^1.49.0",
    "turndown": "^7.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^20.11.0",
    "@types/turndown": "^5.0.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "oclif": {
    "commands": "./dist/commands"
  }
}
